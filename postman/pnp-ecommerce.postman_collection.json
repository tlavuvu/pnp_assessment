{
  "info": {
    "_postman_id": "7d02e3e4-f086-48bd-b1f0-b0f58c846f1f",
    "name": "PnP Ecommerce Assessment",
    "description": "Postman collection for the Spring Boot ecommerce assessment API. The collection uses collection variables for the base URL, seeded credentials, and IDs captured from create requests.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "basic",
    "basic": [
      {
        "key": "username",
        "value": "{{username}}",
        "type": "string"
      },
      {
        "key": "password",
        "value": "{{password}}",
        "type": "string"
      }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Actuator Health",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "actuator",
                "health"
              ]
            },
            "description": "Public health endpoint."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('service is up', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('UP');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products?page={{page}}&size={{size}}&sort={{productSort}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "{{page}}"
                },
                {
                  "key": "size",
                  "value": "{{size}}"
                },
                {
                  "key": "sort",
                  "value": "{{productSort}}"
                }
              ]
            },
            "description": "Lists products using the pageable query parameters supported by Spring Data."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "if (body.content && body.content.length > 0) {",
                  "  pm.collectionVariables.set('productId', String(body.content[0].id));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Product By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products",
                "{{productId}}"
              ]
            },
            "description": "Fetches a single product. By default the collection starts with seeded product ID 1."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Product (Admin)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{adminUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Lavazza Oro 1kg\",\n  \"description\": \"Medium roast, 100% arabica\",\n  \"price\": 249.99,\n  \"stock\": 40\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "products"
              ]
            },
            "description": "Creates a product. Requires ADMIN credentials."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.collectionVariables.set('productId', String(body.id));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerReference\": \"cust-0001\",\n  \"items\": [\n    {\n      \"productId\": {{productId}},\n      \"quantity\": 2\n    },\n    {\n      \"productId\": 2,\n      \"quantity\": 1\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "orders"
              ]
            },
            "description": "Places an order using USER credentials. The first line item uses the current productId collection variable."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var body = pm.response.json();",
                  "pm.collectionVariables.set('orderId', String(body.id));"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Order By Id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "orders",
                "{{orderId}}"
              ]
            },
            "description": "Retrieves an order using the stored orderId variable."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Cancel Order (Admin)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{adminUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders/{{orderId}}/cancel",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "orders",
                "{{orderId}}",
                "cancel"
              ]
            },
            "description": "Cancels an order. Requires ADMIN credentials."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('order is cancelled', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.status).to.eql('CANCELLED');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Oversell Order (Expect 409)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{userUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{userPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"customerReference\": \"cust-oversell\",\n  \"items\": [\n    {\n      \"productId\": {{productId}},\n      \"quantity\": 999999\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "orders"
              ]
            },
            "description": "Negative-path example to verify the standard error envelope for insufficient stock."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 409', function () {",
                  "  pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('error envelope includes code', function () {",
                  "  var body = pm.response.json();",
                  "  pm.expect(body.code).to.eql('INSUFFICIENT_STOCK');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "Top Products Report (Admin)",
          "request": {
            "auth": {
              "type": "basic",
              "basic": [
                {
                  "key": "username",
                  "value": "{{adminUsername}}",
                  "type": "string"
                },
                {
                  "key": "password",
                  "value": "{{adminPassword}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/top-products?from={{reportFrom}}&to={{reportTo}}&limit={{reportLimit}}&status={{reportStatus}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reports",
                "top-products"
              ],
              "query": [
                {
                  "key": "from",
                  "value": "{{reportFrom}}"
                },
                {
                  "key": "to",
                  "value": "{{reportTo}}"
                },
                {
                  "key": "limit",
                  "value": "{{reportLimit}}"
                },
                {
                  "key": "status",
                  "value": "{{reportStatus}}"
                }
              ]
            },
            "description": "Runs the top-products report. Dates must be ISO-8601 instants."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }

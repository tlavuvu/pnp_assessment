# -----------------------------------------------------------------------------
# Environment variables referenced by application.yml.
# Copy to `.env` (gitignored) or export in your shell before running locally.
#
# Spring Boot does NOT auto-load .env files. Consume this via:
#   - IDE run configuration ("EnvFile" plugin, IntelliJ native env, etc.)
#   - `set -a; source .env; set +a; mvn spring-boot:run`
#   - Docker Compose `env_file:` entry
# -----------------------------------------------------------------------------

# --- Runtime profile -----------------------------------------------------------
# Valid values: dev, test, prod (profile files live in src/main/resources/).
SPRING_PROFILES_ACTIVE=dev

# --- HTTP ---------------------------------------------------------------------
SERVER_PORT=8080

# --- Database (PostgreSQL 16) -------------------------------------------------
# Match these to the container started in README.md → "One-time local database
# setup". Change them for staging/prod; never commit real secrets.
DB_URL=jdbc:postgresql://localhost:5432/pnp_ecommerce
DB_USER=pnp
DB_PASSWORD=pnp
